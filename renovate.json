{
  "extends": [
    "config:base",
    "group:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["digest", "patch", "minor", "pin"],
      "automerge": true
    }
  ],
  "pip_requirements": {
    "enabled": true
  },
  "enabledManagers": ["pip_requirements", "poetry", "pipenv", "pre-commit"],
  "platformAutomerge": true,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "ignoreScripts": false
}
